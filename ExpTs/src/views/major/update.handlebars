<div class="mt-4 flex">
  <h3>Lista de cursos</h3>
  <h4><a href="/major"><i class="bi bi-arrow-left-square"></i>Voltar os cursos</a></h4>
</div>

<div class="card ms-5 mt-4" style="width: 18rem;">
  <div class="card-body">
    <h5 class="card-title">{{major.name}}</h5>
    <h6 class="card-subtitle mb-2 text-body-secondary">{{major.code}}</h6>
  </div>
</div>
<form class="myform" action="/major/update/{{major.id}}" method="post">
  {{> majorForm}}
</form>
