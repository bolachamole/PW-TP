<link rel="stylesheet" href="/css/forms.css">
<form class="myform">
	<h4>
		Criação do curso
	</h4>
	<div class="form-group">
		<label for="exampleFormControlTextarea1">Nome</label>
		<input type="text" class="form-control" id="majorName">
	</div>
	<div class="form-group">
		<label for="exampleFormControlTextarea1">Sigla</label>
		<input type="text" class="form-control" id="majorCode">
	</div>
	<div class="form-group">
		<label for="exampleFormControlTextarea1">Descrição</label>
		<textarea class="form-control" id="majorDesc" rows="3"></textarea>
	</div>
	<button type="button" onclick="createMajor()" class="btn btn-primary">Enviar</button>
</form>

<script src="/js/createMajor.js"></script>
