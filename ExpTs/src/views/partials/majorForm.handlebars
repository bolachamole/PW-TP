<link rel="stylesheet" href="/css/forms.css">
<div class="form-group">
  <label for="inputNome" class="col-sm-2 col-form-label">Nome</label>
  <div class="col-sm-10">
    <input type="text" class="form-control" id="inputNome" name="name" value={{major.name}}>
  </div>
</div>
<div class="form-group">
  <label for="inputCode" class="col-sm-2 col-form-label">Sigla</label>
  <div class="col-sm-10">
    <input type="text" class="form-control" id="inputCode" name="code" value={{major.code}}>
  </div>
</div>
<div class="form-group">
  <label for="inputDesc" class="col-sm-2 col-form-label">Descrição</label>
  <textarea class="form-control" id="inputDesc" rows="3" name="description">{{major.description}}</textarea>
</div>
<button type="submit" class="btn btn-primary">Enviar</button>
